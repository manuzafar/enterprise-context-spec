{
  "$schema": "https://a2a-protocol.org/schemas/agent-card.json",
  "name": "Enterprise Context Agent",
  "description": "Provides organizational context (strategy, constraints, team structures, regulatory requirements) for AI agents operating in enterprise environments. Enables agents to understand and respect organizational boundaries.",
  "version": "1.0.0",
  "protocol": "a2a/1.0",
  "provider": {
    "organization": "Enterprise Context Spec",
    "url": "https://github.com/your-org/enterprise-context-spec",
    "contact": "support@example.com"
  },
  "capabilities": {
    "streaming": false,
    "pushNotifications": false,
    "statefulness": false
  },
  "interfaces": [
    {
      "type": "jsonrpc",
      "version": "2.0",
      "endpoint": "/rpc"
    }
  ],
  "skills": [
    {
      "id": "get_context",
      "name": "Get Enterprise Context",
      "description": "Retrieve merged enterprise context with inheritance (company → division → team). Returns organizational knowledge including strategy, constraints, technology landscape, regulatory requirements, and team structures.",
      "tags": ["context", "enterprise", "organization"],
      "input": {
        "type": "object",
        "required": ["level"],
        "properties": {
          "level": {
            "type": "string",
            "enum": ["company", "division", "team"],
            "description": "Context level to retrieve. Higher levels are automatically included via inheritance."
          },
          "division": {
            "type": "string",
            "description": "Division name. Required if level is 'division' or 'team'."
          },
          "team": {
            "type": "string",
            "description": "Team name. Required if level is 'team'."
          },
          "sections": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Optional filter to return only specific sections (e.g., ['constraints', 'technology', 'regulatory'])"
          }
        }
      },
      "output": {
        "type": "object",
        "description": "Merged enterprise context following Enterprise Context Spec schema"
      },
      "examples": [
        {
          "input": { "level": "company" },
          "description": "Get company-wide context only"
        },
        {
          "input": { "level": "team", "division": "Operations", "team": "Customer Portal" },
          "description": "Get full inherited context for Customer Portal team"
        }
      ]
    },
    {
      "id": "check_constraints",
      "name": "Check Constraints",
      "description": "Validate a proposed action against enterprise constraints including budget thresholds, regulatory requirements, technical constraints, timeline blackouts, and team capacity.",
      "tags": ["validation", "constraints", "compliance"],
      "input": {
        "type": "object",
        "required": ["action"],
        "properties": {
          "action": {
            "type": "string",
            "description": "Description of the proposed action to validate"
          },
          "team": {
            "type": "string",
            "description": "Team context to check against (optional, uses company-level if not specified)"
          },
          "action_type": {
            "type": "string",
            "enum": ["technical", "budget", "timeline", "regulatory", "organizational"],
            "description": "Category of action for more specific constraint checking"
          },
          "estimated_cost": {
            "type": "number",
            "description": "Estimated cost in dollars for budget constraint checking"
          },
          "target_date": {
            "type": "string",
            "format": "date",
            "description": "Target date for timeline constraint checking (blackout periods)"
          }
        }
      },
      "output": {
        "type": "object",
        "properties": {
          "allowed": {
            "type": "boolean",
            "description": "Whether the action is permissible given constraints"
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "description": "Confidence in the assessment"
          },
          "concerns": {
            "type": "array",
            "items": { "type": "string" },
            "description": "List of potential concerns or issues"
          },
          "blockers": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Hard blockers that prevent the action"
          },
          "relevant_constraints": {
            "type": "array",
            "description": "Applicable constraints from context"
          },
          "recommendations": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Suggestions to address concerns"
          }
        }
      }
    },
    {
      "id": "get_stakeholders",
      "name": "Get Stakeholders",
      "description": "Identify relevant stakeholders, approvers, and decision forums for a given initiative based on type and cost thresholds.",
      "tags": ["stakeholders", "governance", "approval"],
      "input": {
        "type": "object",
        "required": ["initiative_type"],
        "properties": {
          "initiative_type": {
            "type": "string",
            "enum": ["technical", "product", "regulatory", "budget", "organizational"],
            "description": "Type of initiative to identify stakeholders for"
          },
          "estimated_cost": {
            "type": "number",
            "description": "Estimated cost in dollars for budget-based approval routing"
          },
          "team": {
            "type": "string",
            "description": "Team context for team-specific stakeholders"
          },
          "division": {
            "type": "string",
            "description": "Division context for division-specific stakeholders"
          }
        }
      },
      "output": {
        "type": "object",
        "properties": {
          "approvers": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "role": { "type": "string" },
                "contact": { "type": "string" },
                "threshold": { "type": "string" }
              }
            },
            "description": "Required approvers for this initiative"
          },
          "stakeholders": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "role": { "type": "string" },
                "interest": { "type": "string" }
              }
            },
            "description": "Stakeholders to inform or consult"
          },
          "decision_forum": {
            "type": "string",
            "description": "Relevant decision forum for this initiative"
          },
          "gate_level": {
            "type": "string",
            "description": "Approval gate level (L0, L1, L2, L3)"
          }
        }
      }
    },
    {
      "id": "get_ubiquitous_language",
      "name": "Get Ubiquitous Language",
      "description": "Retrieve domain terminology definitions to ensure consistent language usage across agents.",
      "tags": ["language", "terminology", "ddd"],
      "input": {
        "type": "object",
        "properties": {
          "terms": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Specific terms to look up (optional, returns all if not specified)"
          },
          "division": {
            "type": "string",
            "description": "Division for division-specific terminology"
          }
        }
      },
      "output": {
        "type": "object",
        "additionalProperties": {
          "type": "string"
        },
        "description": "Dictionary of term → definition mappings"
      }
    },
    {
      "id": "check_team_capacity",
      "name": "Check Team Capacity",
      "description": "Check if a team has capacity for additional work based on cognitive load metrics.",
      "tags": ["capacity", "team", "cognitive-load"],
      "input": {
        "type": "object",
        "required": ["team"],
        "properties": {
          "team": {
            "type": "string",
            "description": "Team name to check capacity for"
          },
          "work_type": {
            "type": "string",
            "enum": ["feature", "maintenance", "investigation", "support"],
            "description": "Type of work being considered"
          },
          "estimated_effort": {
            "type": "string",
            "description": "Estimated effort (e.g., '2 sprints', '3 story points')"
          }
        }
      },
      "output": {
        "type": "object",
        "properties": {
          "has_capacity": {
            "type": "boolean",
            "description": "Whether team has capacity for additional work"
          },
          "current_load": {
            "type": "string",
            "enum": ["low", "moderate", "high", "overloaded"],
            "description": "Current cognitive load level"
          },
          "spare_capacity": {
            "type": "string",
            "description": "Available capacity description"
          },
          "blockers": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Current blockers or concerns"
          },
          "recommendation": {
            "type": "string",
            "description": "Recommendation for proceeding"
          }
        }
      }
    }
  ],
  "security": {
    "schemes": {
      "bearer": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      },
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    },
    "defaultScheme": "bearer"
  },
  "extensions": {
    "enterprise-context": {
      "version": "1.0.0",
      "specUrl": "https://github.com/your-org/enterprise-context-spec"
    }
  }
}
